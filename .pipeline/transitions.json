{
  "stages": ["plan", "test", "sprint", "review", "done", "failed"],
  "transitions": {
    "plan_ready": { "from": "plan", "to": "test" },
    "tests_ready": { "from": "test", "to": "sprint" },
    "sprint_complete": { "from": "sprint", "to": "review" },
    "review_complete": { "from": "review", "to": "done" },
    "stage_failed": { "from": "*", "to": "failed" },
    "retry_plan": { "from": "failed", "to": "plan" },
    "retry_test": { "from": "failed", "to": "test" },
    "retry_sprint": { "from": "failed", "to": "sprint" },
    "review_to_test": { "from": "review", "to": "test" },
    "review_to_specced": { "from": "review", "to": "plan" }
  },
  "gates": {
    "sprint": {
      "description": "Sub-gates within the sprint stage (TRIO protocol)",
      "sequence": ["green", "wiring", "visual", "hidden", "activation"],
      "checks": {
        "green": "All visible tests pass",
        "wiring": "Entry-reachability check passes (orphaned modules, dead imports)",
        "visual": "UI visual check passes (UI projects only, after changeset includes UI files)",
        "hidden": "Hidden regression tests pass (behavioral invariants, contract violations)",
        "activation": "Feature reachable from entry point"
      }
    }
  }
}
